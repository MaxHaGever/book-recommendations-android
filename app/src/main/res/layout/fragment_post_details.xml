<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    tools:context=".ui.postdetails.PostDetailsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:id="@+id/postDetailsHeaderLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/postDetailsBackButton"
                style="@style/AppHeaderButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:text="Back"
                android:textAllCaps="false" />

            <TextView
                style="@style/AppScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:paddingHorizontal="92dp"
                android:text="Post Details" />

        </FrameLayout>

        <ProgressBar
            android:id="@+id/postDetailsProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postDetailsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/postDetailsImageView"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/surface_tint"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/default_book" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/postDetailsTitleTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="Book Title" />

                    <TextView
                        android:id="@+id/postDetailsAuthorTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        tools:text="Author Name" />

                    <TextView
                        android:id="@+id/postDetailsOwnerTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        tools:text="Shared by User" />

                    <TextView
                        android:id="@+id/postDetailsDescriptionTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        tools:text="Full review text appears here." />

                    <LinearLayout
                        android:id="@+id/ownerActionsLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/editPostButton"
                            style="@style/AppPrimaryButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="Edit" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/deletePostButton"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Delete"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/error"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
